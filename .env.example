# ═══════════════════════════════════════════════════
# BIBAZ — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════

# ─── Database (Hostinger MySQL) ───
DATABASE_URL="mysql://your_db_user:your_db_password@your_db_host:3306/your_db_name?connection_limit=10"
# Separate DB vars (used by lib/db.ts with explicit config)
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="your_db_user"
DB_PASSWORD="your_db_password"
DB_NAME="your_db_name"

# ─── NextAuth.js ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"
AUTH_TRUST_HOST="true"

# ─── Cloudinary (Media Storage) ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Upstash Redis (Caching + Rate Limiting) ───
UPSTASH_REDIS_REST_URL="your-redis-rest-url"
UPSTASH_REDIS_REST_TOKEN="your-redis-rest-token"

# ─── Email (Phase 1: Hostinger SMTP) ───
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"

# ─── Email (Phase 2: Resend — uncomment when ready) ───
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxxxx"

# ─── Payment (Phase 2+) ───
# SSLCOMMERZ_STORE_ID="your-store-id"
# SSLCOMMERZ_STORE_PASSWORD="your-store-password"
# SSLCOMMERZ_IS_SANDBOX="true"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
