# ═══════════════════════════════════════════════════
# BIBAZ — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════

# ─── Database (Hostinger MySQL) ───
DATABASE_URL="mysql://u713214996_Majed2010:Majed2010@@localhost:3306/u713214996_bibaz?connection_limit=10
"

# ─── NextAuth.js ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ─── Cloudinary (Media Storage) ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Upstash Redis (Caching + Rate Limiting) ───
UPSTASH_REDIS_URL="your-redis-url"
UPSTASH_REDIS_TOKEN="your-redis-token"

# ─── Sentry (Error Tracking) ───
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ─── Email (Phase 1: Hostinger SMTP) ───
EMAIL_PROVIDER="hostinger"
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"

# ─── Email (Phase 2: Resend — uncomment when ready) ───
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxxxx"

# ─── Payment (Phase 2+) ───
# SSLCOMMERZ_STORE_ID="your-store-id"
# SSLCOMMERZ_STORE_PASSWORD="your-store-password"
# SSLCOMMERZ_IS_SANDBOX="true"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
